# user-overrides.yaml.example
# Personal correction patterns for slide-inspector.
#
# To use: copy to ~/.claude/skills/slide-inspector/user-overrides.yaml and edit.
# Or generate automatically by invoking "calibrate slide-inspector" — the calibration
# procedure mines your CC history and proposes patterns for you to approve.
#
# Each check is applied IN ADDITION TO the built-in defaults. Use this for patterns
# specific to your style, your domain, your audience, or your recurring AI bugs.

overrides:
  # Override default thresholds. Comment out to keep defaults.
  # density_word_threshold: 40        # default: 40 (presenter mode)
  # density_word_critical: 60         # default: 60
  # element_count_warn: 8             # default: 8
  # marooned_image_max_pct: 15        # default: 15

checks:
  # ─── Example: domain-specific character/asset consistency ───
  - id: character-consistency
    description: "Named recurring characters (mascots, personas) should look identical across slides"
    severity: warning
    type: visual
    pattern: |
      If the deck mentions recurring named characters or mascots
      (e.g., personas in a customer-journey deck, mascot illustrations),
      visually verify each occurrence is the SAME character — not a similar
      one regenerated by the AI. AI illustration tools tend to drift between calls.
    derived_from: "Manual addition — frequent issue with AI-generated character illustrations"
    enabled: true

  # ─── Example: asset filename pattern ───
  - id: avoid-stock-handshake-imagery
    description: "Don't use stock handshake/lightbulb/puzzle metaphors"
    severity: suggestion
    type: regex
    pattern: "(handshake|lightbulb|puzzle_piece|gears_metaphor|rocket_launch)\\.(png|jpg|svg)"
    note: "Applies to image filenames in <a:blip r:embed>"
    derived_from: "Manual addition — these metaphors are AI-cliché"
    enabled: true

  # ─── Example: brand color enforcement ───
  - id: brand-color-palette
    description: "Only use approved brand colors in body text"
    severity: warning
    type: color-allowlist
    pattern:
      allowed_text_colors:
        - "1A1A1A"   # primary text
        - "5C5C5C"   # secondary text
        - "0066FF"   # accent / link
        - "FFFFFF"   # inverse on dark
    derived_from: "Manual addition — brand palette enforcement"
    enabled: false   # disabled by default; enable per project

  # ─── Example: forbidden phrasing ───
  - id: no-corporate-platitudes
    description: "Forbidden corporate-speak that creeps into AI-generated decks"
    severity: warning
    type: regex
    pattern: "\\b(synergy|leverage our|circle back|low-hanging fruit|move the needle|drink the kool-aid)\\b"
    derived_from: "Manual addition — personal style preference"
    enabled: true

  # ─── Example: required sections in every long deck ───
  - id: long-deck-needs-callouts
    description: "Decks ≥15 slides should have at least one stat-callout slide (not just bullets)"
    severity: suggestion
    type: deck-structural
    pattern: "if deck_slide_count >= 15: at_least_one_slide_with_large_number_glyph"
    derived_from: "Manual addition — variety check for long decks"
    enabled: false

# ─── How calibration writes here ───
# When you run "calibrate slide-inspector", the procedure appends approved patterns
# below this line with auto-generated IDs and "derived_from" notes citing your
# verbatim correction examples. Hand-edit any check anytime; set `enabled: false`
# to silence a check without deleting it.
